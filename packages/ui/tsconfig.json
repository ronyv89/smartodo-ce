{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@repo/ui/*": ["./src/*"]
    },
    "outDir": "dist",
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["@testing-library/jest-dom", "node", "react", "react-dom"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
